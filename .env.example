# Copia questo file in `.env.local` e incolla i valori del tuo progetto Supabase
# (Dashboard Supabase → Project Settings → API / Data API).
# La chiave "anon/public" è pensata per stare nel browser: non è un segreto,
# ma .env.local resta comunque fuori da git.
#
# Su Vercel gli stessi due valori vanno in: Project → Settings → Environment Variables.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
